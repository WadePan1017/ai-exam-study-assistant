        {
          "key": "B",
          "content_md": "为创造独特成果而开展的临时性工作"
        },
        {
          "key": "C",
          "content_md": "仅指大型工程建设活动"
        },
        {
          "key": "D",
          "content_md": "必须由外部客户发起"
        }
      ],
      "answer": {
