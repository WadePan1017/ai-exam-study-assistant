# 个人访问保护
# 至少8个字符。手机首次访问时输入。
APP_ACCESS_KEY=replace-with-your-private-access-key

# 用于签名30天有效的访问Cookie，至少32个随机字符。
# 可使用 `openssl rand -hex 32` 生成。
APP_SESSION_SECRET=replace-with-at-least-32-random-characters

# Supabase服务端连接。不要添加 NEXT_PUBLIC_ 前缀。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
